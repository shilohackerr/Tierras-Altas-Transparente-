# ══════════════════════════════════════════════════════
# _headers — Cabeceras de Seguridad
# Portal Ciudadano Transparente · Alcaldía de Tierras Altas
# Versión: 2.0 — Marzo 2026
# Cumple: AIG · ANTAI · Contraloría · OWASP Top 10
# ══════════════════════════════════════════════════════

/*
  # ── Transporte seguro (HTTPS obligatorio 2 años)
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload

  # ── Prevenir clickjacking (AIG requisito)
  X-Frame-Options: DENY

  # ── Prevenir sniffing de tipos MIME
  X-Content-Type-Options: nosniff

  # ── XSS básico (legacy browsers)
  X-XSS-Protection: 1; mode=block

  # ── Control de referencia — no filtrar URL a terceros
  Referrer-Policy: strict-origin-when-cross-origin

  # ── Aislamiento de origen cruzado
  Cross-Origin-Opener-Policy: same-origin-allow-popups
  Cross-Origin-Resource-Policy: cross-origin

  # ── Permisos de APIs del navegador — solo las necesarias
  Permissions-Policy: geolocation=(self), camera=(), microphone=(), payment=(), usb=()

  # ── Content Security Policy sin unsafe-inline
  Content-Security-Policy: default-src 'self'; script-src 'self' https://www.panamacompra.gob.pa https://svi3.tribunal-electoral.gob.pa https://ocds.open-contracting.org; style-src 'self' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://www.panamacompra.gob.pa https://svi3.tribunal-electoral.gob.pa https://ocds.open-contracting.org https://api.bac.net https://yappy.bac.net https://secure.clave.com.pa https://e-certchile.pa https://digifact.com.pa; frame-src 'none'; object-src 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests

  # ── Caché — datos públicos, actualización cada hora
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

# ── Panel admin: sin caché, sin indexación
/admin/*
  X-Robots-Tag: noindex, nofollow
  Cache-Control: no-store, no-cache, must-revalidate
  X-Frame-Options: DENY
  Content-Security-Policy: default-src 'self'; script-src 'self'; style-src 'self'; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; frame-src 'none'; object-src 'none'

# ── API estática — acceso público de lectura para datos OCDS
/api/*
  Cache-Control: public, max-age=1800, stale-while-revalidate=3600
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Methods: GET

# ── Service Worker — siempre fresco
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
